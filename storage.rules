rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /product-images/{imageId} {
      allow read: if true;
      allow write: if request.resource != null
        && request.resource.contentType.matches('image/.*')
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
